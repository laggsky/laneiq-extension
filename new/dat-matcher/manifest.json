{
  "manifest_version": 3,
  "name": "LaneIQ \u2014 DAT Load Matcher",
  "version": "1.16",
  "description": "Highlights DAT loads that match your freight history. Color-coded by tier: same lane + broker, same lane, or same origin.",
  "permissions": [
    "storage",
    "tabs",
    "windows",
    "unlimitedStorage",
    "identity"
  ],
  "oauth2": {
    "client_id": "37040200160-4eceklacq36gac24eudi5ei3rs13160n.apps.googleusercontent.com",
    "scopes": ["https://www.googleapis.com/auth/gmail.send"]
  },
  "background": {
    "service_worker": "background.js"
  },
  "host_permissions": [
    "*://*.dat.com/*",
    "*://one.dat.com/*",
    "https://maps.googleapis.com/*",
    "https://laneiq-backend-production.up.railway.app/*"
  ],
  "icons": {
    "16":  "icons/icon16.png",
    "48":  "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "action": {
    "default_popup": "popup.html",
    "default_title": "DAT Lane Matcher",
    "default_icon": {
      "16":  "icons/icon16.png",
      "48":  "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "content_scripts": [
    {
      "matches": [
        "*://*.dat.com/*",
        "*://one.dat.com/*"
      ],
      "js": [
        "content.js"
      ],
      "css": [
        "content.css"
      ],
      "run_at": "document_idle"
    }
  ]
}